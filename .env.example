# Lutra 环境配置
# 复制为 .env 后填入实际值: cp .env.example .env
# 用法: source .env && python agent.py

# ── Claude API (必填) ──
export CLAUDE_API_KEY="sk-your-api-key"
export CLAUDE_BASE_URL="https://api.anthropic.com"
export CLAUDE_MODEL="claude-opus-4-6"
export CLAUDE_MAX_TOKENS="4096"

# ── 工作目录 (可选，默认为 $HOME) ──
export PROJECT_DIR="/path/to/your/project"

# ── 机器人名称 (可选) ──
export BOT_NAME="Lutra"

# ── 飞书机器人 (必填，否则仅 HTTP API 可用) ──
export FEISHU_APP_ID="cli_your_app_id"
export FEISHU_APP_SECRET="your_app_secret"

# ── 飞书机器人 (可选) ──
export FEISHU_CHAT_ID=""

# ── JIRA (可选，配置后启用 JIRA 工具) ──
export JIRA_SERVER="https://jira.example.com"
export JIRA_PAT="your_personal_access_token"
# aegis_cas 通常无需手动配置 — 会自动从 Chrome 浏览器 cookie 读取
# 仅在无头环境或 Chrome 不可用时才需手动填写
export JIRA_AEGIS_CAS=""

# ── Mimo 脱敏 (可选，配置后 JIRA 分析自动脱敏) ──
export MIMO_API_KEY=""
export MIMO_BASE_URL="http://model.mify.ai.srv/v1"
export MIMO_MODEL="mimo-v2-flash"
export MIMO_PROVIDER_ID="xiaomi"

# ── GitLab (可选，配置后启用 MR Review 工具) ──
export GITLAB_URL="https://git.n.xiaomi.com"
export GITLAB_PAT=""
export GITLAB_PROJECT=""                  # 留空自动从 git remote 检测
export GITLAB_BOT_USERNAME=""             # bot 的 GitLab 用户名，防自循环
export GITLAB_POLL_INTERVAL="0"          # 轮询间隔(秒)，0=不启用
export GITLAB_POLL_CRON=""               # 固定时间如 "09:00,14:00"，空=不启用

# ── Agent 行为 (可选，以下为默认值) ──
export MAX_TOOL_ROUNDS="30"
export CONTEXT_THRESHOLD="150000"
export SESSION_TTL="3600"

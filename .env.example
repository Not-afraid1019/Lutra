# ClawBot 环境配置
# 复制为 .env 后填入实际值: cp .env.example .env
# 用法: source .env && python agent.py

# ── Claude API (必填) ──
export CLAUDE_API_KEY="sk-your-api-key"
export CLAUDE_BASE_URL="https://api.anthropic.com"
export CLAUDE_MODEL="claude-opus-4-6"
export CLAUDE_MAX_TOKENS="4096"

# ── 工作目录 (可选，默认为 $HOME) ──
export PROJECT_DIR="/path/to/your/project"

# ── 机器人名称 (可选) ──
export BOT_NAME="ClawBot"

# ── 飞书机器人 (必填，否则仅 HTTP API 可用) ──
export FEISHU_APP_ID="cli_your_app_id"
export FEISHU_APP_SECRET="your_app_secret"

# ── 飞书机器人 (可选) ──
export FEISHU_CHAT_ID=""

# ── Agent 行为 (可选，以下为默认值) ──
export MAX_TOOL_ROUNDS="30"
export CONTEXT_THRESHOLD="150000"
export SESSION_TTL="3600"
